{
  "_meta": {
    "purpose": "Per-panel analyte catalogue. Drives both random value generation in src/generators/analytes.js and the printed reference-range column in src/templates/*.js. Adding a new analyte here is sufficient to surface it in the rendered PDF; no template changes are required as long as the new entry fits an existing group.",
    "fields": {
      "code": "stable identifier (kebab-case). Treat as load-bearing — computed-formula identifiers in analytes.js reference these.",
      "name": "display name as it should appear on the printed report",
      "unit": "measurement unit; printed verbatim",
      "precision": "decimal places used when rounding the random sample for display",
      "method": "optional, printed in the 'Method' column when present",
      "ranges": "reference interval as {male,female,common} → {low, high}; sex-specific entries take precedence when present, otherwise the 'common' fallback is used",
      "physMin": "physiological floor used when sampling 'low' values — never go below this, even if a low draw would otherwise produce a non-survivable number",
      "physMax": "physiological ceiling, same idea",
      "computed": "if present, marks the analyte as derived from other analytes in the same panel; the value generator computes it from sibling samples instead of drawing independently",
      "kind": "optional. One of 'quantitative' | 'semi-quantitative' | 'qualitative'. Defaults to 'quantitative' when absent. Non-quantitative analytes (urine routine, microscopy) draw a string from `options` instead of a numeric sample. The sampler flags 'N' when the picked option is in `normalOptions`, otherwise 'H'.",
      "options": "array of allowed display strings for qualitative / semi-quantitative analytes. Sampler picks uniformly across this list. Required when `kind` is 'qualitative' or 'semi-quantitative'.",
      "normalOptions": "subset of `options` considered normal (sampler emits flag 'N' for these; any other pick gets 'H'). Required alongside `options`."
    },
    "notes": {
      "ranges_provenance": "Reference intervals are drawn from common Indian-laboratory adult reporting conventions. Where literature varies, conservative wide ranges are used: ESR upper bounds, anti-TPO cutoffs, transferrin saturation, fructosamine, and apolipoprotein cutoffs are particularly assay-dependent and should be treated as approximate.",
      "urine_semi_quant": "Urinalysis dipstick fields use the standard semi-quantitative {Negative, Trace, 1+, 2+, 3+, 4+} scale. Urobilinogen is unique in that 'Trace' is still considered normal — handled via per-analyte `normalOptions`."
    }
  },

