{
  "_meta": {
    "purpose": "Per-panel analyte catalogue. Drives both random value generation in src/generators/analytes.js and the printed reference-range column in src/templates/*.js. Adding a new analyte here is sufficient to surface it in the rendered PDF; no template changes are required as long as the new entry fits an existing group.",
    "fields": {
      "code": "stable identifier (kebab-case)",
      "name": "display name as it should appear on the printed report",
      "unit": "measurement unit; printed verbatim",
      "precision": "decimal places used when rounding the random sample for display",
      "method": "optional, printed in the 'Method' column when present",
      "ranges": "reference interval as {male,female,common} → {low, high}; sex-specific entries take precedence when present, otherwise the 'common' fallback is used",
      "physMin": "physiological floor used when sampling 'low' values — never go below this, even if a low draw would otherwise produce a non-survivable number",
      "physMax": "physiological ceiling, same idea",
      "computed": "if present, marks the analyte as derived from other analytes in the same panel; the value generator computes it from sibling samples instead of drawing independently"
    }
  },

  "cbc": {
