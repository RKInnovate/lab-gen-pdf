node_modules/
*.log

# Generated PDF output — ~2k files per full run, multi-MB total.
# Regenerate locally; never commit. The directory itself is kept
# via test-sample/.gitkeep so scripts can drop into a known path.
test-sample/*
!test-sample/.gitkeep

# Output of `pnpm run generate:repro` — the pinned-seed/pinned-now
# determinism check. Same throwaway status as test-sample/.
test-sample-repro/

# Vendored Devanagari TTFs MUST be committed so a fresh clone can
# render the bilingual layout without network access. If any future
# broad rule starts ignoring `assets/`, this negation keeps the TTFs
# (and the OFL license alongside them) tracked.
!assets/fonts/*.ttf
!assets/fonts/OFL.txt
